#!/usr/bin/env bash
set -euo pipefail

print_usage() {
  cat <<'USAGE'
Usage: boomhauer [options]

Runs a Arlen app from the current app root (or ARLEN_APP_ROOT).
By default, boomhauer watches for source/template/config/public changes,
restarting the server when files change and rebuilding only when build inputs
change.

Options:
  --watch        Enable watch mode (default)
  --no-watch     Disable watch mode
  --once         Serve one request and exit (disables watch)
  --prepare-only Compile app/server and exit without starting it
  --help, -h     Show this help

Environment:
  ARLEN_APP_ROOT         App root to run (default: current directory)
  ARLEN_FRAMEWORK_ROOT   Arlen framework root (auto-detected from script path)
USAGE
}

script_path="${BASH_SOURCE[0]}"
script_dir="$(cd "$(dirname "$script_path")" && pwd -P)"
default_framework_root="$(cd "$script_dir/.." && pwd)"
framework_root="${ARLEN_FRAMEWORK_ROOT:-$default_framework_root}"

path_looks_like_windows_absolute() {
  local path="$1"
  [[ "$path" =~ ^[A-Za-z]:[\\/] ]] || [[ "$path" =~ ^\\\\ ]]
}

path_is_absolute() {
  local path="$1"
  [[ "$path" == /* ]] || path_looks_like_windows_absolute "$path"
}

normalize_host_path() {
  local raw="$1"
  if [[ -z "$raw" ]]; then
    printf '%s\n' "$PWD"
    return
  fi
  if command -v cygpath >/dev/null 2>&1 && path_looks_like_windows_absolute "$raw"; then
    cygpath -au "$raw"
    return
  fi
  if path_is_absolute "$raw"; then
    printf '%s\n' "$raw"
    return
  fi
  printf '%s\n' "$PWD/$raw"
}

resolve_gnustep_sh() {
  local candidate=""
  local gnustep_makefiles=""
  if [[ -n "${GNUSTEP_SH:-}" && -f "${GNUSTEP_SH:-}" ]]; then
    printf '%s\n' "$GNUSTEP_SH"
    return 0
  fi
  if [[ -n "${GNUSTEP_MAKEFILES:-}" ]]; then
    candidate="${GNUSTEP_MAKEFILES}/GNUstep.sh"
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi
  if command -v gnustep-config >/dev/null 2>&1; then
    gnustep_makefiles="$(gnustep-config --variable=GNUSTEP_MAKEFILES 2>/dev/null || true)"
    if [[ -n "$gnustep_makefiles" ]]; then
      candidate="${gnustep_makefiles}/GNUstep.sh"
      if [[ -f "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  fi
  for candidate in \
    /clang64/share/GNUstep/Makefiles/GNUstep.sh \
    /usr/GNUstep/System/Library/Makefiles/GNUstep.sh
  do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

detect_windows_preview() {
  local host_os=""
  if [[ "${MSYSTEM:-}" == "CLANG64" || "${MSYSTEM:-}" == "MINGW64" || "${MSYSTEM:-}" == "UCRT64" ]]; then
    return 0
  fi
  if command -v gnustep-config >/dev/null 2>&1; then
    host_os="$(gnustep-config --variable=GNUSTEP_HOST_OS 2>/dev/null || true)"
    if [[ "$host_os" == *mingw* ]]; then
      return 0
    fi
  fi
  return 1
}

windows_preview=0
if detect_windows_preview; then
  windows_preview=1
fi

if [[ ! -f "$framework_root/GNUmakefile" || ! -d "$framework_root/src/Arlen" ]]; then
  echo "boomhauer: invalid framework root: $framework_root" >&2
  echo "boomhauer: set ARLEN_FRAMEWORK_ROOT to a valid Arlen repository root" >&2
  exit 1
fi

if ! gnustep_sh="$(resolve_gnustep_sh)"; then
  echo "boomhauer: GNUstep.sh could not be resolved from the active toolchain" >&2
  exit 1
fi

app_root="$(normalize_host_path "${ARLEN_APP_ROOT:-$PWD}")"
app_root="$(cd "$app_root" && pwd -P)"

watch_mode=1
prepare_only=0
print_routes_requested=0
server_args=()
for arg in "$@"; do
  case "$arg" in
    --watch)
      watch_mode=1
      ;;
    --no-watch)
      watch_mode=0
      ;;
    --help|-h)
      print_usage
      exit 0
      ;;
    --prepare-only)
      watch_mode=0
      prepare_only=1
      ;;
    --once)
      watch_mode=0
      server_args+=("$arg")
      ;;
    --print-routes)
      watch_mode=0
      print_routes_requested=1
      server_args+=("$arg")
      ;;
    *)
      server_args+=("$arg")
      ;;
  esac
done

is_app_root=0
if [[ -f "$app_root/config/app.plist" ]] && ([[ -f "$app_root/src/main.m" ]] || [[ -f "$app_root/app_lite.m" ]]); then
  is_app_root=1
fi

if [[ $is_app_root -eq 0 ]]; then
  if [[ $windows_preview -eq 1 ]]; then
    echo "boomhauer: repository-root boomhauer is not yet supported on Windows CLANG64 preview" >&2
    echo "boomhauer: run from a generated app root and use --no-watch, --prepare-only, or --print-routes" >&2
    exit 1
  fi
  cd "$framework_root"
  if [[ $watch_mode -eq 1 ]]; then
    make arlen >/dev/null
    exec "$framework_root/build/arlen" boomhauer --watch "${server_args[@]}"
  fi

  if [[ $prepare_only -eq 1 ]]; then
    echo "boomhauer: prepare-only mode; building app artifacts without starting the server"
  elif [[ $print_routes_requested -eq 1 ]]; then
    echo "boomhauer: route inspection mode; ensuring artifacts are current before printing routes"
  fi

  make boomhauer >/dev/null
  if [[ $prepare_only -eq 1 ]]; then
    exit 0
  fi
  export ARLEN_APP_ROOT="$app_root"
  exec "$framework_root/build/boomhauer" "${server_args[@]}"
fi

if [[ $windows_preview -eq 1 && $watch_mode -eq 1 ]]; then
  echo "boomhauer: watch mode is not yet supported on Windows CLANG64 preview" >&2
  echo "boomhauer: rerun with --no-watch, --prepare-only, --print-routes, or --once" >&2
  exit 1
fi

state_root="$app_root/.boomhauer"
build_root="$state_root/build"
app_binary="$build_root/boomhauer-app"
app_makefile="$build_root/AppGNUmakefile"
framework_lib="$framework_root/build/lib/libArlenFramework.a"
gen_root="$build_root/gen/templates"
module_manifest_root="$gen_root/manifests"
app_template_root="$gen_root/app"
error_output_file="$state_root/last_build_error.log"
error_meta_file="$state_root/last_build_error.meta"
mkdir -p "$gen_root" "$module_manifest_root"

normalized_non_negative_integer() {
  local raw="$1"
  local fallback="$2"
  if [[ "$raw" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$raw"
    return
  fi
  printf '%s\n' "$fallback"
}

build_error_retry_seconds="$(normalized_non_negative_integer "${ARLEN_BOOMHAUER_BUILD_ERROR_RETRY_SECONDS:-2}" 2)"
build_error_auto_refresh_seconds="$(normalized_non_negative_integer "${ARLEN_BOOMHAUER_BUILD_ERROR_AUTO_REFRESH_SECONDS:-3}" 3)"
build_error_recovery_hint="${ARLEN_BOOMHAUER_BUILD_ERROR_RECOVERY_HINT:-Fix the compile error and save a watched file. Boomhauer retries automatically every ${build_error_retry_seconds} seconds while the diagnostic server is active.}"

file_fingerprint_fields() {
  local path="$1"
  python3 - "$path" <<'PY'
import os
import sys

path = sys.argv[1]
try:
    stat_result = os.stat(path, follow_symlinks=False)
except OSError:
    print("0|0|0")
    raise SystemExit(0)

print(f"{stat_result.st_size}|{stat_result.st_mtime_ns}|{stat_result.st_ctime_ns}")
PY
}

append_fingerprint_entries() {
  local base="$1"
  local label="$2"
  shift 2

  local found=0
  local rel path

  for rel in "$@"; do
    path="$base/$rel"
    if [[ -d "$path" ]]; then
      while IFS= read -r file; do
        local rel_file
        rel_file="${file#"$base"/}"
        printf '%s|%s|' "$label" "$rel_file"
        file_fingerprint_fields "$file"
        found=1
      done < <(find "$path" -type f | sort)
    elif [[ -f "$path" ]]; then
      printf '%s|%s|' "$label" "$rel"
      file_fingerprint_fields "$path"
      found=1
    fi
  done

  if [[ $found -eq 0 ]]; then
    printf '%s|__empty__\n' "$label"
  fi
}

hash_fingerprint_stream() {
  sort | python3 -c "import hashlib, sys; sys.stdout.write(hashlib.sha256(sys.stdin.buffer.read()).hexdigest() + '\n')"
}

runtime_fingerprint() {
  {
    printf 'app_root|%s\n' "$app_root"
    printf 'framework_root|%s\n' "$framework_root"
    printf 'enable_yyjson|%s\n' "${ARLEN_ENABLE_YYJSON:-1}"
    printf 'enable_llhttp|%s\n' "${ARLEN_ENABLE_LLHTTP:-1}"
    append_fingerprint_entries "$app_root" "app" src templates modules config public app_lite.m config/modules.plist
    append_fingerprint_entries "$framework_root" "framework" src modules GNUmakefile tools/eocc.m
  } | hash_fingerprint_stream
}

move_file_if_changed() {
  local tmp_path="$1"
  local final_path="$2"
  mkdir -p "$(dirname "$final_path")"
  if [[ ! -f "$final_path" ]] || ! cmp -s "$tmp_path" "$final_path"; then
    mv "$tmp_path" "$final_path"
    return
  fi
  rm -f "$tmp_path"
}

object_path_for_app_source() {
  local source_path="$1"
  local relative_path
  if [[ "$source_path" == "$app_root/"* ]]; then
    relative_path="${source_path#"$app_root"/}"
    printf '%s\n' "$build_root/obj/app/${relative_path%.m}.o"
    return
  fi
  if [[ "$source_path" == "$build_root/"* ]]; then
    relative_path="${source_path#"$build_root"/}"
    printf '%s\n' "$build_root/obj/${relative_path%.m}.o"
    return
  fi
  printf '%s\n' "$build_root/obj/misc/${source_path##*/}.o"
}

transpile_templates() {
  mkdir -p "$app_template_root" "$gen_root/modules" "$module_manifest_root"

  if [[ -d "$gen_root/modules" ]]; then
    while IFS= read -r existing_dir; do
      local module_id
      module_id="$(basename "$existing_dir")"
      if [[ ! -d "$app_root/modules/$module_id" ]]; then
        rm -rf "$existing_dir" "$module_manifest_root/$module_id.json"
      fi
    done < <(find "$gen_root/modules" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  fi

  if [[ -d "$app_root/modules" ]]; then
    while IFS= read -r module_root; do
      local module_id module_template_root
      module_id="$(basename "$module_root")"
      module_template_root="$module_root/Resources/Templates"
      if [[ ! -d "$module_template_root" ]]; then
        rm -rf "$gen_root/modules/$module_id" "$module_manifest_root/$module_id.json"
        continue
      fi
      mapfile -t module_template_files < <(find "$module_template_root" -type f -name '*.html.eoc' | sort)
      if [[ ${#module_template_files[@]} -eq 0 ]]; then
        rm -rf "$gen_root/modules/$module_id" "$module_manifest_root/$module_id.json"
        continue
      fi
      local filtered_module_template_files=()
      local relative_template_path override_template_path
      for template_path in "${module_template_files[@]}"; do
        relative_template_path="${template_path#"$module_template_root"/}"
        override_template_path="$app_root/templates/modules/$module_id/$relative_template_path"
        if [[ -f "$override_template_path" ]]; then
          continue
        fi
        filtered_module_template_files+=("$template_path")
      done
      if [[ ${#filtered_module_template_files[@]} -eq 0 ]]; then
        rm -rf "$gen_root/modules/$module_id" "$module_manifest_root/$module_id.json"
        continue
      fi
      "$framework_root/build/eocc" \
        --template-root "$module_template_root" \
        --output-dir "$gen_root" \
        --manifest "$module_manifest_root/$module_id.json" \
        --logical-prefix "modules/$module_id" \
        "${filtered_module_template_files[@]}"
    done < <(find "$app_root/modules" -mindepth 1 -maxdepth 1 -type d | sort)
  fi

  if [[ ! -d "$app_root/templates" ]]; then
    rm -rf "$app_template_root"
    return
  fi

  mapfile -t template_files < <(find "$app_root/templates" -type f -name '*.html.eoc' | sort)
  if [[ ${#template_files[@]} -eq 0 ]]; then
    rm -rf "$app_template_root"
    return
  fi

  "$framework_root/build/eocc" \
    --template-root "$app_root/templates" \
    --output-dir "$app_template_root" \
    --manifest "$app_template_root/manifest.json" \
    "${template_files[@]}"
}

list_current_generated_sources() {
  local template_path relative_template_path override_template_path

  if [[ -d "$app_root/templates" ]]; then
    while IFS= read -r template_path; do
      relative_template_path="${template_path#"$app_root/templates"/}"
      printf '%s\n' "$app_template_root/${relative_template_path}.m"
    done < <(find "$app_root/templates" -type f -name '*.html.eoc' 2>/dev/null | sort)
  fi

  if [[ -d "$app_root/modules" ]]; then
    while IFS= read -r module_root; do
      local module_id module_template_root
      module_id="$(basename "$module_root")"
      module_template_root="$module_root/Resources/Templates"
      if [[ ! -d "$module_template_root" ]]; then
        continue
      fi
      while IFS= read -r template_path; do
        relative_template_path="${template_path#"$module_template_root"/}"
        override_template_path="$app_root/templates/modules/$module_id/$relative_template_path"
        if [[ -f "$override_template_path" ]]; then
          continue
        fi
        printf '%s\n' "$gen_root/modules/$module_id/${relative_template_path}.m"
      done < <(find "$module_template_root" -type f -name '*.html.eoc' 2>/dev/null | sort)
    done < <(find "$app_root/modules" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  fi
}

record_build_failure() {
  local stage="$1"
  local command="$2"
  local exit_code="$3"
  local output_file="$4"

  command="${command//$'\n'/ }"
  cp "$output_file" "$error_output_file"
  {
    printf 'stage=%s\n' "$stage"
    printf 'command=%s\n' "$command"
    printf 'exit_code=%s\n' "$exit_code"
    printf 'timestamp_utc=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } >"$error_meta_file"
}

clear_build_failure_state() {
  rm -f "$error_output_file" "$error_meta_file"
}

emit_app_makefile() {
  local enable_yyjson="${ARLEN_ENABLE_YYJSON:-1}"
  local enable_llhttp="${ARLEN_ENABLE_LLHTTP:-1}"
  local gnustep_objc_flags
  local gnustep_base_libs
  local postgresql_include_flags=""
  local platform_link_libs="-ldl"
  mapfile -t app_sources < <(find "$app_root/src" -type f -name '*.m' 2>/dev/null | sort)
  mapfile -t framework_module_source_dirs < <(find "$framework_root/modules" -mindepth 2 -maxdepth 2 -type d -name 'Sources' 2>/dev/null | sort)
  mapfile -t app_module_source_dirs < <(
    find "$app_root/modules" -mindepth 2 -maxdepth 2 -type d -name 'Sources' 2>/dev/null | sort
  )
  mapfile -t app_module_sources < <(find "$app_root/modules" -path '*/Sources/*.m' -type f 2>/dev/null | sort)
  mapfile -t generated_sources < <(list_current_generated_sources)
  local -a include_args
  local -a app_objects
  local source_path object_path dep_path
  local tmp_makefile

  if [[ -f "$app_root/app_lite.m" ]]; then
    app_sources+=("$app_root/app_lite.m")
  fi
  if [[ ${#app_module_sources[@]} -gt 0 ]]; then
    app_sources+=("${app_module_sources[@]}")
  fi
  if [[ ${#app_sources[@]} -eq 0 ]]; then
    echo "boomhauer: no app source files found under $app_root" >&2
    echo "boomhauer: expected src/main.m (full mode) or app_lite.m (lite mode)" >&2
    return 1
  fi

  include_args=(
    "-I$framework_root/src"
    "-I$framework_root/src/Arlen"
    "-I$framework_root/src/Arlen/Core"
    "-I$framework_root/src/Arlen/Data"
    "-I$framework_root/src/Arlen/HTTP"
    "-I$framework_root/src/Arlen/MVC/Controller"
    "-I$framework_root/src/Arlen/MVC/Middleware"
    "-I$framework_root/src/Arlen/MVC/Routing"
    "-I$framework_root/src/Arlen/MVC/Template"
    "-I$framework_root/src/Arlen/MVC/View"
    "-I$framework_root/src/Arlen/Support"
    "-I$framework_root/src/Arlen/Support/third_party/argon2/include"
    "-I$framework_root/src/Arlen/Support/third_party/argon2/src"
    "-I$framework_root/src/MojoObjc"
    "-I$framework_root/src/MojoObjc/Core"
    "-I$framework_root/src/MojoObjc/Data"
    "-I$framework_root/src/MojoObjc/HTTP"
    "-I$framework_root/src/MojoObjc/MVC/Controller"
    "-I$framework_root/src/MojoObjc/MVC/Middleware"
    "-I$framework_root/src/MojoObjc/MVC/Routing"
    "-I$framework_root/src/MojoObjc/MVC/Template"
    "-I$framework_root/src/MojoObjc/MVC/View"
    "-I$framework_root/src/MojoObjc/Support"
    "-I$app_root/src"
  )
  for module_source_dir in "${framework_module_source_dirs[@]}"; do
    include_args+=("-I$module_source_dir")
  done
  for module_source_dir in "${app_module_source_dirs[@]}"; do
    include_args+=("-I$module_source_dir")
  done

  set +u
  # shellcheck disable=SC1090
  source "$gnustep_sh"
  set -u
  gnustep_objc_flags="$(gnustep-config --objc-flags)"
  gnustep_base_libs="$(gnustep-config --base-libs)"
  postgresql_include_flags="$(pkg-config --cflags-only-I libpq 2>/dev/null || true)"
  if [[ -z "$postgresql_include_flags" ]]; then
    if [[ -d /clang64/include/postgresql ]]; then
      postgresql_include_flags="-I/clang64/include/postgresql"
    elif [[ -d /usr/include/postgresql ]]; then
      postgresql_include_flags="-I/usr/include/postgresql"
    fi
  fi
  if [[ $windows_preview -eq 1 ]]; then
    platform_link_libs="-lws2_32"
  fi

  tmp_makefile="$(mktemp)"
  {
    printf 'SHELL := bash\n'
    printf '.RECIPEPREFIX = >\n\n'
    printf 'GNUSTEP_SH := %s\n' "$gnustep_sh"
    printf 'APP_BINARY := %s\n' "$app_binary"
    printf 'OBJECTS_READY := %s\n' "$build_root/.objects-ready"
    printf 'FRAMEWORK_LIB := %s\n' "$framework_lib"
    printf 'GNUSTEP_OBJC_FLAGS := %s\n' "$gnustep_objc_flags"
    printf 'POSTGRESQL_INCLUDE_FLAGS := %s\n' "$postgresql_include_flags"
    printf 'ARLEN_PLATFORM_LINK_LIBS := %s\n' "$platform_link_libs"
    printf 'BASE_LINK_LIBS := %s -lcrypto -ldispatch $(ARLEN_PLATFORM_LINK_LIBS)\n' "$gnustep_base_libs"
    printf 'OBJC_FLAGS := $(GNUSTEP_OBJC_FLAGS) -fobjc-arc -fPIC -DARLEN_ENABLE_YYJSON=%s -DARLEN_ENABLE_LLHTTP=%s -DARLEN_WINDOWS_PREVIEW=%s -DARGON2_NO_THREADS=1\n' "$enable_yyjson" "$enable_llhttp" "$windows_preview"
    printf 'INCLUDE_FLAGS :='
    for source_path in "${include_args[@]}"; do
      printf ' %s' "$source_path"
    done
    if [[ -n "$postgresql_include_flags" ]]; then
      printf ' $(POSTGRESQL_INCLUDE_FLAGS)'
    fi
    printf '\n'
    printf 'ALL_OBJECTS :='
    for source_path in "${app_sources[@]}" "${generated_sources[@]}"; do
      object_path="$(object_path_for_app_source "$source_path")"
      app_objects+=("$object_path")
      printf ' %s' "$object_path"
    done
    printf '\n'
    printf 'ALL_DEPFILES := $(ALL_OBJECTS:.o=.d)\n\n'
    printf '$(OBJECTS_READY): $(ALL_OBJECTS) $(lastword $(MAKEFILE_LIST))\n'
    printf '>mkdir -p $(@D)\n'
    printf '>touch $@\n\n'
    printf '$(APP_BINARY): $(OBJECTS_READY) $(FRAMEWORK_LIB) $(lastword $(MAKEFILE_LIST))\n'
    printf '>mkdir -p $(@D)\n'
    printf '>source $(GNUSTEP_SH) && clang $(OBJC_FLAGS) $(INCLUDE_FLAGS) $(ALL_OBJECTS) $(FRAMEWORK_LIB) -o $(APP_BINARY) $(BASE_LINK_LIBS)\n\n'
    for source_path in "${app_sources[@]}" "${generated_sources[@]}"; do
      object_path="$(object_path_for_app_source "$source_path")"
      dep_path="${object_path%.o}.d"
      printf '%s: %s $(lastword $(MAKEFILE_LIST))\n' "$object_path" "$source_path"
      printf '>mkdir -p $(@D)\n'
      printf '>source $(GNUSTEP_SH) && clang $(OBJC_FLAGS) $(INCLUDE_FLAGS) -MMD -MP -MF %s -c %s -o %s\n\n' \
        "$dep_path" "$source_path" "$object_path"
    done
    printf -- '-include $(wildcard $(ALL_DEPFILES))\n'
  } >"$tmp_makefile"

  move_file_if_changed "$tmp_makefile" "$app_makefile"
  return 0
}

framework_artifacts_are_current() {
  make -q -C "$framework_root" "$framework_root/build/eocc" "$framework_lib" >/dev/null 2>&1
}

framework_archive_contains_sanitizers() {
  local archive_path="${1:-$framework_lib}"
  local symbol_dump
  [[ -f "$archive_path" ]] || return 1
  symbol_dump="$(mktemp)"
  if ! nm -A "$archive_path" >"$symbol_dump" 2>/dev/null; then
    rm -f "$symbol_dump"
    return 1
  fi

  if grep -Eq '(__asan_|__ubsan_)' "$symbol_dump"; then
    rm -f "$symbol_dump"
    return 0
  fi

  rm -f "$symbol_dump"
  return 1
}

emit_framework_link_mode_diagnostic() {
  local output_file="$1"

  cat >"$output_file" <<EOF
boomhauer: selected framework root contains sanitizer-instrumented framework artifacts:
  $framework_lib
boomhauer: app-root builds link libArlenFramework.a without sanitizer runtimes, so this archive cannot be reused here.
boomhauer: rebuild $framework_root cleanly without sanitizer flags before using ARLEN_FRAMEWORK_ROOT for app-root boomhauer commands.
EOF
}

ensure_framework_artifacts_ready() {
  local output_file="$1"

  if framework_artifacts_are_current; then
    if framework_archive_contains_sanitizers; then
      echo "boomhauer: [1/4] detected sanitizer-instrumented framework artifacts; rebuilding clean framework artifacts"
      if {
        make -C "$framework_root" clean &&
          make -C "$framework_root" "$framework_root/build/eocc" "$framework_lib"
      } >"$output_file" 2>&1; then
        if [[ -s "$output_file" ]]; then
          cat "$output_file"
        fi
      else
        local status=$?
        record_build_failure \
          "tooling" \
          "make -C $framework_root clean && make -C $framework_root $framework_root/build/eocc $framework_lib" \
          "$status" \
          "$output_file"
        return "$status"
      fi
    else
      echo "boomhauer: [1/4] reusing current framework tools and libraries"
    fi
  else
    echo "boomhauer: [1/4] checking tool freshness and building framework artifacts"
    if make -C "$framework_root" "$framework_root/build/eocc" "$framework_lib" >"$output_file" 2>&1; then
      if [[ -s "$output_file" ]]; then
        cat "$output_file"
      fi
    else
      local status=$?
      record_build_failure "tooling" "make -C $framework_root $framework_root/build/eocc $framework_lib" "$status" "$output_file"
      return "$status"
    fi
  fi

  if framework_archive_contains_sanitizers; then
    emit_framework_link_mode_diagnostic "$output_file"
    record_build_failure \
      "framework_link_mode" \
      "verify $framework_lib is free of sanitizer instrumentation" \
      2 \
      "$output_file"
    return 2
  fi

  : >"$output_file"
  return 0
}

run_app_make_target() {
  local target="$1"
  local reuse_message="$2"
  local build_message="$3"
  local failure_stage="$4"
  local failure_command="$5"
  local tmp_output
  tmp_output="$(mktemp)"

  if make -s -C "$build_root" -f "$app_makefile" -q "$target" >/dev/null 2>&1; then
    echo "$reuse_message"
    rm -f "$tmp_output"
    return 0
  fi

  echo "$build_message"
  if make -s -C "$build_root" -f "$app_makefile" "$target" >"$tmp_output" 2>&1; then
    if [[ -s "$tmp_output" ]]; then
      cat "$tmp_output"
    fi
    rm -f "$tmp_output"
    return 0
  else
    local status=$?
    record_build_failure "$failure_stage" "$failure_command" "$status" "$tmp_output"
    rm -f "$tmp_output"
    return "$status"
  fi
}

compile_app() {
  local enable_yyjson="${ARLEN_ENABLE_YYJSON:-1}"
  local enable_llhttp="${ARLEN_ENABLE_LLHTTP:-1}"
  local tmp_output
  tmp_output="$(mktemp)"

  if [[ "$enable_yyjson" != "0" && "$enable_yyjson" != "1" ]]; then
    printf 'boomhauer: ARLEN_ENABLE_YYJSON must be 0 or 1 (got %s)\n' "$enable_yyjson" >"$tmp_output"
    record_build_failure "feature_flags" "validate ARLEN_ENABLE_YYJSON" 2 "$tmp_output"
    rm -f "$tmp_output"
    return 2
  fi
  if [[ "$enable_llhttp" != "0" && "$enable_llhttp" != "1" ]]; then
    printf 'boomhauer: ARLEN_ENABLE_LLHTTP must be 0 or 1 (got %s)\n' "$enable_llhttp" >"$tmp_output"
    record_build_failure "feature_flags" "validate ARLEN_ENABLE_LLHTTP" 2 "$tmp_output"
    rm -f "$tmp_output"
    return 2
  fi

  if ensure_framework_artifacts_ready "$tmp_output"; then
    :
  else
    local status=$?
    rm -f "$tmp_output"
    return "$status"
  fi

  echo "boomhauer: [2/4] transpiling templates"
  if transpile_templates >"$tmp_output" 2>&1; then
    if [[ -s "$tmp_output" ]]; then
      cat "$tmp_output"
    fi
  else
    local status=$?
    record_build_failure "template_transpile" "$framework_root/build/eocc --manifest ... --output-dir $gen_root" "$status" "$tmp_output"
    rm -f "$tmp_output"
    return "$status"
  fi

  if emit_app_makefile >"$tmp_output" 2>&1; then
    :
  else
    local status=$?
    record_build_failure "app_discovery" "emit incremental app makefile" "$status" "$tmp_output"
    rm -f "$tmp_output"
    return "$status"
  fi
  rm -f "$tmp_output"

  if ! run_app_make_target \
      "$build_root/.objects-ready" \
      "boomhauer: [3/4] reusing current app objects" \
      "boomhauer: [3/4] compiling app objects" \
      "compile_objects" \
      "make -C $build_root -f $app_makefile $build_root/.objects-ready"; then
    return 1
  fi

  if ! run_app_make_target \
      "$app_binary" \
      "boomhauer: [4/4] reusing current app binary" \
      "boomhauer: [4/4] linking app binary" \
      "link" \
      "make -C $build_root -f $app_makefile $app_binary"; then
    return 1
  fi

  clear_build_failure_state
  return 0
}

ensure_app_built() {
  compile_app
}

child_pid=""
child_mode=""
stop_requested=0
error_server_ready=0
next_build_retry_at=0

ensure_error_server_built() {
  if [[ $error_server_ready -eq 1 && -x "$framework_root/build/boomhauer" ]]; then
    return 0
  fi

  if ! make -C "$framework_root" boomhauer >/dev/null; then
    echo "boomhauer: failed to build fallback dev error server" >&2
    return 1
  fi

  error_server_ready=1
  return 0
}

stop_child() {
  if [[ -n "$child_pid" ]] && kill -0 "$child_pid" 2>/dev/null; then
    kill -TERM "$child_pid" 2>/dev/null || true
    wait "$child_pid" 2>/dev/null || true
  fi
  child_pid=""
  child_mode=""
}

on_signal() {
  stop_requested=1
  stop_child
}

trap on_signal INT TERM

start_app_child() {
  export ARLEN_APP_ROOT="$app_root"
  next_build_retry_at=0
  "$app_binary" "${server_args[@]}" &
  child_pid="$!"
  child_mode="app"
}

start_error_child() {
  if ! ensure_error_server_built; then
    return 1
  fi
  export ARLEN_APP_ROOT="$app_root"
  export ARLEN_BOOMHAUER_BUILD_ERROR_FILE="$error_output_file"
  export ARLEN_BOOMHAUER_BUILD_ERROR_META_FILE="$error_meta_file"
  export ARLEN_BOOMHAUER_BUILD_ERROR_RETRY_SECONDS="$build_error_retry_seconds"
  export ARLEN_BOOMHAUER_BUILD_ERROR_AUTO_REFRESH_SECONDS="$build_error_auto_refresh_seconds"
  export ARLEN_BOOMHAUER_BUILD_ERROR_RECOVERY_HINT="$build_error_recovery_hint"
  if [[ "$build_error_retry_seconds" -gt 0 ]]; then
    next_build_retry_at=$(( $(date +%s) + build_error_retry_seconds ))
  else
    next_build_retry_at=0
  fi
  "$framework_root/build/boomhauer" "${server_args[@]}" &
  child_pid="$!"
  child_mode="build_error"
}

run_once() {
  if [[ $prepare_only -eq 1 ]]; then
    echo "boomhauer: prepare-only mode; building app artifacts without starting the server"
  elif [[ $print_routes_requested -eq 1 ]]; then
    echo "boomhauer: route inspection mode; ensuring artifacts are current before printing routes"
  fi
  if ensure_app_built; then
    :
  else
    local status=$?
    cat "$error_output_file" >&2 || true
    exit "$status"
  fi
  if [[ $prepare_only -eq 1 ]]; then
    exit 0
  fi
  export ARLEN_APP_ROOT="$app_root"
  exec "$app_binary" "${server_args[@]}"
}

if [[ $watch_mode -eq 0 ]]; then
  run_once
fi

last_runtime_fingerprint="$(runtime_fingerprint)"

echo "boomhauer: watching $app_root"

while [[ $stop_requested -eq 0 ]]; do
  desired_mode="app"
  if ! ensure_app_built; then
    desired_mode="build_error"
  fi

  if [[ "$desired_mode" == "app" ]]; then
    if [[ "$child_mode" != "app" ]] || [[ -z "$child_pid" ]] || ! kill -0 "$child_pid" 2>/dev/null; then
      stop_child
      start_app_child
    fi
  else
    if [[ "$child_mode" != "build_error" ]] || [[ -z "$child_pid" ]] || ! kill -0 "$child_pid" 2>/dev/null; then
      stop_child
      echo "boomhauer: build failed, serving diagnostic error page" >&2
      if ! start_error_child; then
        exit 1
      fi
    fi
  fi

  restart_reason=""
  while [[ $stop_requested -eq 0 ]] && [[ -n "$child_pid" ]] && kill -0 "$child_pid" 2>/dev/null; do
    sleep 1
    current_runtime_fingerprint="$(runtime_fingerprint)"
    if [[ "$current_runtime_fingerprint" != "$last_runtime_fingerprint" ]]; then
      last_runtime_fingerprint="$current_runtime_fingerprint"
      echo "boomhauer: change detected, restarting..."
      restart_reason="change"
      stop_child
      break
    fi
    if [[ "$child_mode" == "build_error" && "$build_error_retry_seconds" -gt 0 ]]; then
      current_epoch="$(date +%s)"
      if [[ "$current_epoch" -ge "$next_build_retry_at" ]]; then
        next_build_retry_at=$(( current_epoch + build_error_retry_seconds ))
        echo "boomhauer: retrying failed build..."
        restart_reason="build_retry"
        stop_child
        break
      fi
    fi
  done

  if [[ $stop_requested -eq 1 ]]; then
    break
  fi

  if [[ -n "$child_pid" ]]; then
    set +e
    wait "$child_pid"
    child_status=$?
    set -e
    child_pid=""
    previous_mode="$child_mode"
    child_mode=""
    if [[ -z "$restart_reason" && $child_status -ne 0 ]]; then
      echo "boomhauer: server exited with status $child_status" >&2
      if [[ "$previous_mode" == "build_error" && -f "$error_output_file" ]]; then
        cat "$error_output_file" >&2 || true
      fi
      exit "$child_status"
    fi
  fi

done

exit 0
