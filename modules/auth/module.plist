{
  identifier = "auth";
  version = "1.0.0";
  principalClass = "ALNAuthModule";
  compatibility = {
    arlenVersion = ">= 0.1.0";
  };
  config = {
    defaults = {
      session = {
        enabled = YES;
      };
      csrf = {
        enabled = YES;
        allowQueryParamFallback = YES;
      };
      authModule = {
        defaultRedirect = "/";
        bootstrapAdminEmails = ();
        mfa = {
          sms = {
            enabled = NO;
            allowEnrollment = YES;
            allowChallenge = YES;
            allowPrimaryFactor = NO;
            phoneManagementRequiresMFA = YES;
            recentMFAMaxAgeSeconds = 900;
            resendCooldownSeconds = 30;
            maxSendAttemptsPerSession = 5;
            maxVerifyAttemptsPerSession = 8;
            locale = "";
            accountSID = "";
            authToken = "";
            apiKeySID = "";
            apiKeySecret = "";
            verifyServiceSID = "";
            testVerificationCode = "";
          };
        };
        paths = {
          prefix = "/auth";
          apiPrefix = "api";
        };
        providers = {
          stub = {
            enabled = YES;
            email = "stub-user@example.test";
            displayName = "Stub Provider User";
            clientSecret = "auth-module-stub-provider-secret-0123456789abcdef";
          };
        };
        hooks = {
        };
      };
    };
    requiredKeys = (
      "session.secret",
      "database.connectionString"
    );
  };
}
