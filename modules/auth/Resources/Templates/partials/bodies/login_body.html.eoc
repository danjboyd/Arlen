<% if (!ALNEOCInclude(out, ctx, [ctx objectForKey:@"authPartialFormShell"], error)) { return nil; } %>
<% NSArray *authProviders = [ctx objectForKey:@"authProviders"] ?: @[]; %>
<% if ([authProviders count] > 0) { %>
  <% NSString *providerButtonsTemplate = [ctx objectForKey:@"authFragmentProviderLoginButtons"] ?: @"modules/auth/fragments/provider_login_buttons"; %>
  <% if (!ALNEOCInclude(out, ctx, providerButtonsTemplate, error)) { return nil; } %>
<% } %>
