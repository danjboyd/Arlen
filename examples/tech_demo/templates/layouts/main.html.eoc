<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= $pageTitle %></title>
    <link rel="stylesheet" href="/static/tech_demo.css">
    <script src="/arlen/live.js" defer></script>
  </head>
  <body>
    <header class="shell">
      <p class="eyebrow">Composition-first EOC demo</p>
      <h1><%= $pageTitle %></h1>
      <p class="tagline"><%= $tagline %></p>
      <%@ include "partials/_nav" %>
    </header>

    <div class="shell layout-grid">
      <main>
        <%@ yield %>
      </main>
      <aside class="sidebar">
        <%@ yield "sidebar" %>
      </aside>
    </div>

    <footer class="shell footer">
      <p>Arlen tech demo. This page is rendered from compiled <code>.html.eoc</code> templates.</p>
    </footer>
  </body>
</html>
