{
  "schema_version": 1,
  "name": "arlen_comparative_benchmark_contract_v1",
  "source_program": "../ArlenBenchmarking",
  "contract_scope": "Imported lightweight benchmark manifests/config for Arlen drift detection. This file is not an executable runner config in this repo.",
  "warmup": {
    "duration_seconds": 15,
    "requests_per_scenario": 30
  },
  "measured": {
    "duration_seconds": 60,
    "requests_per_scenario": 120,
    "concurrency_levels": [1, 8, 32, 128],
    "repeats": 3
  },
  "framework_defaults": {
    "arlen": {
      "server": "boomhauer",
      "environment_mode": "production",
      "workers": 1
    },
    "fastapi": {
      "server": "uvicorn",
      "workers": 1
    }
  },
  "scenarios_manifests": {
    "http_api": "tests/fixtures/benchmarking/comparative_scenarios.v1.json",
    "db": "tests/fixtures/benchmarking/comparative_scenarios.db.v1.json"
  },
  "reproducibility": {
    "max_cv_ratio": 0.4
  }
}
