{
  "version": "phase5a-capabilities-v1",
  "adapters": {
    "postgresql": {
      "adapter": "postgresql",
      "batch_execution_mode": "sequential_same_connection",
      "conflict_resolution_mode": "on_conflict",
      "dialect": "postgresql",
      "json_feature_family": "jsonb_ops",
      "pagination_syntax": "limit_offset",
      "prepared_statement_cache_eviction": "lru",
      "returning_mode": "returning",
      "savepoint_release_mode": "explicit",
      "support_tier": "first_class",
      "supports_batch_execution": true,
      "supports_builder_compilation_cache": true,
      "supports_builder_diagnostics": true,
      "supports_connection_liveness_checks": true,
      "supports_cte": true,
      "supports_for_update": true,
      "supports_lateral_join": true,
      "supports_on_conflict": true,
      "supports_recursive_cte": true,
      "supports_result_wrappers": true,
      "supports_savepoint_release": true,
      "supports_savepoints": true,
      "supports_set_operations": true,
      "supports_skip_locked": true,
      "supports_transactions": true,
      "supports_upsert": true,
      "supports_window_clauses": true
    },
    "gdl2": {
      "adapter": "gdl2",
      "batch_execution_mode": "sequential_same_connection",
      "compatibility_mode": "fallback_pg",
