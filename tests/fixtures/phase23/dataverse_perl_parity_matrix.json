  "intentional_omissions": [
    {
      "id": "fetchxml_builder",
      "reason": "Arlen's shipped Dataverse slice is OData-first and does not promise FetchXML builder parity."
    },
    {
      "id": "odata_apply_aggregation",
      "reason": "Arlen's ALNDataverseQuery does not expose Perl's dedicated $apply coverage as part of the supported v1 surface."
    },
    {
      "id": "count_fallback_endpoint_semantics",
      "reason": "Arlen ships query-page count handling but does not expose a separate count API with top=0 and fallback retry semantics."
    },
    {
      "id": "per_table_overrides_and_query_budget_tracing",
      "reason": "Per-table datasource overrides and request-budget tracing are not part of Arlen's Dataverse public contract."
    },
    {
      "id": "preview_sanitize_and_existing_selection_workflows",
      "reason": "Perl's preview sanitization and existing-selection workflows are specific to its table-builder productization and are outside Arlen's shipped Dataverse slice."
    }
  ],
