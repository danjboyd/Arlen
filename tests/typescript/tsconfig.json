{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": false
  },
  "include": [
    "./shared/**/*.ts",
    "./unit/**/*.ts",
    "./react/**/*.ts",
    "./integration/**/*.ts",
    "./generated/arlen/src/**/*.ts"
  ]
}
