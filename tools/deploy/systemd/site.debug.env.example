# Copy to /etc/arlen/<site>.debug.env only during incident response.
# Remove or rename the file after the investigation is finished.

ARLEN_LOG_LEVEL=debug
ARLEN_PERFORMANCE_LOGGING=1
ARLEN_TRACE_PROPAGATION_ENABLED=1
ARLEN_RESPONSE_IDENTITY_HEADERS_ENABLED=1
ARLEN_HEALTH_DETAILS_ENABLED=1
ARLEN_METRICS_ENABLED=1

# Optional extra propane lifecycle copy.
# Ensure the parent directory exists and is writable by the service user.
# ARLEN_PROPANE_LIFECYCLE_LOG=/var/log/arlen/<site>-propane-lifecycle.log

# Optional incident-only behavior changes.
# ARLEN_REQUEST_DISPATCH_MODE=serialized
# ARLEN_MAX_HTTP_SESSIONS=128
