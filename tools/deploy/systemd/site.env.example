# Copy to /etc/arlen/<site>.env and adjust values for the instance.

ARLEN_HOST=127.0.0.1
ARLEN_PORT=3000
ARLEN_LOG_LEVEL=info

# Required for most production apps.
ARLEN_DATABASE_URL=postgres://app:CHANGE_ME@127.0.0.1/app_production

# Required when session middleware is enabled.
ARLEN_SESSION_SECRET=replace-with-32-plus-character-secret

# Optional runtime sizing overrides.
# ARLEN_MAX_HTTP_SESSIONS=256
# ARLEN_MAX_WEBSOCKET_SESSIONS=256

# Optional cluster wiring.
# ARLEN_CLUSTER_ENABLED=1
# ARLEN_CLUSTER_NAME=apps-production
# ARLEN_CLUSTER_EXPECTED_NODES=2
# ARLEN_READINESS_REQUIRES_CLUSTER_QUORUM=1

# Optional async worker supervision through propane accessories.
# ARLEN_PROPANE_JOB_WORKER_COUNT=1
# ARLEN_PROPANE_JOB_WORKER_COMMAND=/srv/arlen/<site>/releases/current/framework/bin/jobs-worker
# ARLEN_PROPANE_JOB_WORKER_RESPAWN_DELAY_MS=250
